# ===== Configuration Ollama =====
# Modèles
OLLAMA_DEFAULT_MODEL=gemma2:2b
OLLAMA_MODELS_TO_PULL=gemma2:2b

# Performance
OLLAMA_NUM_PARALLEL=4
OLLAMA_NUM_THREAD=4
OLLAMA_KEEP_ALIVE=60m

# Host binding
OLLAMA_INTERNAL_PORT=21434

# ===== Configuration Redis =====
REDIS_MAX_MEMORY=1gb
REDIS_HOST=redis
REDIS_PORT=16379
REDIS_INTERNAL_PORT=16379
REDIS_APPENDONLY=yes
REDIS_MAX_MEMORY_POLICY=allkeys-lru

# ===== Configuration PostgreSQL =====
# IMPORTANT: Changer le mot de passe en production!
POSTGRES_VERSION=16
POSTGRES_HOST=postgres
POSTGRES_INTERNAL_PORT=15432
POSTGRES_HOST_PORT=25432
POSTGRES_DB=ollama_db
POSTGRES_USER=ollama_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_INITDB_ARGS=-c max_connections=200 -c shared_buffers=256MB

# PostgreSQL Resources
POSTGRES_CPU_LIMIT=1.0
POSTGRES_CPU_RESERVATION=0.5
POSTGRES_MEMORY_LIMIT=2G
POSTGRES_MEMORY_RESERVATION=1G

# ===== Configuration PgBouncer (Connection Pooling) =====
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=16432
PGBOUNCER_INTERNAL_PORT=16432
PGBOUNCER_HOST_PORT=26432
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=25
PGBOUNCER_MIN_POOL_SIZE=10

# PgBouncer Resources
PGBOUNCER_CPU_LIMIT=0.5
PGBOUNCER_CPU_RESERVATION=0.25
PGBOUNCER_MEMORY_LIMIT=512M
PGBOUNCER_MEMORY_RESERVATION=256M

# ===== Configuration Warmer =====
WARMER_ENABLED=true
WARMER_INTERVAL=300
WARMER_PROMPT=ping

# ===== Ressources Docker =====
# OLLAMA
OLLAMA_CPU_LIMIT=3.5
OLLAMA_CPU_RESERVATION=4.0
OLLAMA_MEMORY_LIMIT=14G
OLLAMA_MEMORY_RESERVATION=10G

# REDIS
REDIS_CPU_LIMIT=0.5
REDIS_CPU_RESERVATION=0.25
REDIS_MEMORY_LIMIT=1G
REDIS_MEMORY_RESERVATION=512M

# ===== Traefik / Réseau =====
TRAEFIK_NETWORK=coolify
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_TLS=true

# ===== Production Domain =====
PRODUCTION_DOMAIN=bluevaloris.com
OLLAMA_DOMAIN=ollama.bluevaloris.com

# ===== Configuration Manager (Web UI) =====
# Mot de passe administrateur pour l'interface web
CONFIG_ADMIN_PASSWORD=admin
CONFIG_MANAGER_INTERNAL_PORT=18889
CONFIG_MANAGER_HOST_PORT=18888

# Resources pour Config Manager
CONFIG_MANAGER_CPU_LIMIT=0.5
CONFIG_MANAGER_CPU_RESERVATION=0.25
CONFIG_MANAGER_MEMORY_LIMIT=512M
CONFIG_MANAGER_MEMORY_RESERVATION=256M

